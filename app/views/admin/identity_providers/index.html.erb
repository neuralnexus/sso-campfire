<% @page_title = "Identity Providers" %>

<% content_for :nav do %>
  <div class="flex-item-justify-start">
    <%= link_back_to edit_account_path %>
  </div>
  <div class="flex-item-justify-end">
    <%= link_to new_admin_identity_provider_path, class: "btn btn--reversed" do %>
      <%= image_tag "add.svg", aria: { hidden: "true" }, size: 20 %>
      <span>New provider</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide flex flex-column gap">
  <div class="flex align-center gap pad-inline pad-block-start">
    <h1 class="margin-none flex-item-grow">Identity Providers</h1>
  </div>

  <% if @providers.none? %>
    <div class="pad-inline pad-block txt-align-center txt-subtle">
      <p>No identity providers configured. Add one to enable enterprise SSO.</p>
    </div>
  <% else %>
    <menu class="flex flex-column gap margin-none pad">
      <% @providers.each do |provider| %>
        <li class="flex align-center gap pad-block pad-inline fill-shade border-radius">
          <div class="flex-item-grow flex flex-column gap" style="--row-gap: 0.25em">
            <strong><%= provider.name %></strong>
            <span class="txt-subtle txt-small"><%= provider.issuer %></span>
          </div>

          <span class="btn txt-small <%= provider.enabled? ? "btn--positive" : "btn--negative" %>">
            <%= provider.enabled? ? "Enabled" : "Disabled" %>
          </span>

          <span class="txt-subtle txt-small"><%= provider.protocol.upcase %></span>

          <%= link_to admin_identity_provider_path(provider), class: "btn" do %>
            <%= image_tag "arrow-right.svg", aria: { hidden: "true" }, size: 20 %>
            <span class="for-screen-reader">View <%= provider.name %></span>
          <% end %>
        </li>
      <% end %>
    </menu>
  <% end %>
</section>
